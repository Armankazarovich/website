generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  MANAGER     // Менеджер по продажам
  COURIER     // Курьер
  ACCOUNTANT  // Бухгалтер
  WAREHOUSE   // Складчик
  SELLER      // Продавец
}

enum StaffStatus {
  PENDING    // Ждёт подтверждения
  ACTIVE     // Активен
  SUSPENDED  // Заблокирован
}

enum SaleUnit {
  CUBE
  PIECE
  BOTH
}

enum UnitType {
  CUBE
  PIECE
}

enum OrderStatus {
  NEW
  CONFIRMED
  PROCESSING
  SHIPPED
  IN_DELIVERY
  READY_PICKUP
  DELIVERED
  COMPLETED   // Завершён (самовывоз — клиент забрал)
  CANCELLED
}

model User {
  id           String             @id @default(cuid())
  name         String?
  email        String             @unique
  phone        String?
  passwordHash String
  role         Role               @default(USER)
  staffStatus  StaffStatus?
  customRole   String?
  address      String?
  orders          Order[]
  reviews         Review[]
  pushSubs        PushSubscription[]
  assignedTasks   Task[]           @relation("TaskAssignee")
  createdTasks    Task[]           @relation("TaskCreator")
  taskComments    TaskComment[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lastActiveAt    DateTime?        // Последняя активность в системе
}

model Category {
  id             String     @id @default(cuid())
  name           String
  slug           String     @unique
  image          String?
  sortOrder      Int        @default(0)

  // Подкатегории
  parentId       String?
  parent         Category?  @relation("sub", fields: [parentId], references: [id])
  children       Category[] @relation("sub")

  // SEO
  seoTitle       String?
  seoDescription String?

  // Навигация
  showInMenu     Boolean    @default(true)
  showInFooter   Boolean    @default(true)

  products       Product[]
  updatedAt      DateTime   @updatedAt @default(now())
}

model Product {
  id          String           @id @default(cuid())
  slug        String           @unique
  name        String
  description String?
  categoryId  String
  category    Category         @relation(fields: [categoryId], references: [id])
  images      String[]
  saleUnit    SaleUnit         @default(BOTH)
  variants    ProductVariant[]
  active      Boolean          @default(true)
  featured    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ProductVariant {
  id            String      @id @default(cuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  size          String
  pricePerCube  Decimal?    @db.Decimal(10, 2)
  pricePerPiece Decimal?    @db.Decimal(10, 2)
  piecesPerCube Int?
  inStock       Boolean     @default(true)
  stockQty      Int?        // null = не отслеживается; 0 = нет; ≥1 = в наличии
  orderItems    OrderItem[]
  costPrice     CostPrice?
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     Int         @default(autoincrement())
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  guestName       String?
  guestEmail      String?
  guestPhone      String?
  status          OrderStatus @default(NEW)
  totalAmount     Decimal     @db.Decimal(10, 2)
  deliveryCost    Decimal     @default(0) @db.Decimal(10, 2)
  paymentMethod   String      @default("Наличные / Счёт")
  deliveryAddress String?
  comment         String?
  items             OrderItem[]
  tasks             Task[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  deletedAt         DateTime?
  telegramMessageId String?     // ID сообщения в Telegram группе для авто-удаления
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  productName  String
  variantSize  String
  unitType  UnitType
  quantity  Decimal        @db.Decimal(10, 3)
  price     Decimal        @db.Decimal(10, 2)
}

model Review {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  name      String
  rating    Int
  text      String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Promotion {
  id          String    @id @default(cuid())
  title       String
  description String
  discount    Int?
  imageUrl    String?
  validUntil  DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
}

model DeliveryRate {
  id          String @id @default(cuid())
  vehicleName String          // "Газель"
  payload     String          // "1.5 т"
  maxVolume   Float           // 3.5 (м³)
  basePrice   Int             // 3000 (руб.)
  sortOrder   Int    @default(0)
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model SiteSettings {
  id    String @id @default("default")
  key   String @unique
  value String
}

model PartnershipLead {
  id        String   @id @default(cuid())
  name      String
  company   String?
  phone     String
  message   String?
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model CategoryRedirect {
  id        String   @id @default(cuid())
  fromSlug  String   @unique   // старый slug (напр: "kedr", "dsp-mdf-osb")
  toSlug    String?            // новый slug (null = просто /catalog)
  permanent Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  amount      Decimal  @db.Decimal(10, 2)
  category    String   // "Аренда", "Зарплата", "Транспорт", "Реклама", "Прочее"
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
}

model CostPrice {
  id        String  @id @default(cuid())
  variantId String  @unique
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  costPerCube  Decimal? @db.Decimal(10, 2)  // себестоимость за м³
  costPerPiece Decimal? @db.Decimal(10, 2)  // себестоимость за шт
}

// ── Задачи и Канбан ────────────────────────────────────────────────────────────

enum TaskStatus {
  BACKLOG    // Очередь
  TODO       // Сделать
  IN_PROGRESS // В работе
  REVIEW     // На проверке
  DONE       // Готово
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  sortOrder   Int          @default(0)

  // Связи
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdById String?
  createdBy   User?        @relation("TaskCreator", fields: [createdById], references: [id])

  // Опциональная привязка к заказу
  orderId     String?
  order       Order?       @relation(fields: [orderId], references: [id])

  // Даты
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  comments    TaskComment[]
  tags        String[]     @default([])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  text      String
  createdAt DateTime @default(now())
}

// ── Автоворкфлоу ──────────────────────────────────────────────────────────────

model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String?
  active      Boolean  @default(true)

  // Триггер: order_created | order_status_changed | task_overdue | manual
  trigger     String
  // Условия в JSON: { "status": "NEW", "minAmount": 5000 }
  conditions  Json     @default("{}")
  // Действия в JSON: [{ "type": "create_task", "title": "...", "assigneeId": "..." }]
  actions     Json     @default("[]")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  logs        WorkflowLog[]
}

model WorkflowLog {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  trigger    String
  payload    Json     @default("{}")
  result     String   // "ok" | "error"
  error      String?
  createdAt  DateTime @default(now())
}
