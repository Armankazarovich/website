generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String             @id @default(cuid())
  name           String?
  email          String             @unique
  phone          String?
  passwordHash   String
  role           Role               @default(USER)
  address        String?
  avatarUrl      String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  customRole     String?
  staffStatus    StaffStatus?
  lastActiveAt   DateTime?
  arayMemory     ArayMemory?
  arayMessages   ArayMessage[]
  assignedLeads  Lead[]             @relation("LeadAssignee")
  leadActivities LeadActivity[]     @relation("LeadActivityUser")
  orders         Order[]
  pushSubs       PushSubscription[]
  reviews        Review[]
  assignedTasks  Task[]             @relation("TaskAssignee")
  createdTasks   Task[]             @relation("TaskCreator")
  taskComments   TaskComment[]

  @@index([role, staffStatus])
  @@index([lastActiveAt])
}

model Category {
  id             String     @id @default(cuid())
  name           String
  slug           String     @unique
  image          String?
  sortOrder      Int        @default(0)
  parentId       String?
  seoDescription String?
  seoTitle       String?
  showInFooter   Boolean    @default(true)
  showInMenu     Boolean    @default(true)
  updatedAt      DateTime   @default(now()) @updatedAt
  parent         Category?  @relation("sub", fields: [parentId], references: [id])
  children       Category[] @relation("sub")
  products       Product[]
}

model Product {
  id          String           @id @default(cuid())
  slug        String           @unique
  name        String
  description String?
  categoryId  String
  images      String[]
  saleUnit    SaleUnit         @default(BOTH)
  active      Boolean          @default(true)
  featured    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  category    Category         @relation(fields: [categoryId], references: [id])
  variants    ProductVariant[]
  reviews     Review[]

  @@index([categoryId])
  @@index([active])
  @@index([featured])
  @@index([active, featured])
}

model ProductVariant {
  id            String      @id @default(cuid())
  productId     String
  size          String
  pricePerCube  Decimal?    @db.Decimal(10, 2)
  pricePerPiece Decimal?    @db.Decimal(10, 2)
  piecesPerCube Int?
  inStock       Boolean     @default(true)
  stockQty      Int?
  costPrice     CostPrice?
  orderItems    OrderItem[]
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Order {
  id                String      @id @default(cuid())
  orderNumber       Int         @default(autoincrement())
  userId            String?
  guestName         String?
  guestEmail        String?
  guestPhone        String?
  status            OrderStatus @default(NEW)
  totalAmount       Decimal     @db.Decimal(10, 2)
  paymentMethod     String      @default("Наличные / Счёт")
  deliveryAddress   String?
  comment           String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  deliveryCost      Decimal     @default(0) @db.Decimal(10, 2)
  deletedAt         DateTime?
  telegramMessageId String?
  contactMethod     String?
  contactUsername   String?
  discountAmount    Decimal     @default(0) @db.Decimal(10, 2)
  promoCode         String?
  user              User?       @relation(fields: [userId], references: [id])
  items             OrderItem[]
  tasks             Task[]

  @@index([userId, createdAt])
  @@index([status, deletedAt])
  @@index([createdAt])
}

model OrderItem {
  id          String         @id @default(cuid())
  orderId     String
  variantId   String
  productName String
  variantSize String
  unitType    UnitType
  quantity    Decimal        @db.Decimal(10, 3)
  price       Decimal        @db.Decimal(10, 2)
  order       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productName])
}

model Review {
  id           String    @id @default(cuid())
  userId       String?
  productId    String?
  name         String
  rating       Int
  text         String
  images       String[]  @default([])
  approved     Boolean   @default(false)
  likes        Int       @default(0)
  dislikes     Int       @default(0)
  adminReply   String?
  adminReplyAt DateTime?
  createdAt    DateTime  @default(now())
  externalId   String?
  source       String    @default("internal")
  sourceUrl    String?
  user         User?     @relation(fields: [userId], references: [id])
  product      Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([approved, createdAt(sort: Desc)])
  @@index([productId])
}

model Promotion {
  id          String    @id @default(cuid())
  title       String
  description String
  discount    Int?
  imageUrl    String?
  validUntil  DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
}

model DeliveryRate {
  id          String @id @default(cuid())
  vehicleName String
  payload     String
  maxVolume   Float
  basePrice   Int
  sortOrder   Int    @default(0)
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String?
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model SiteSettings {
  id    String @id @default("default")
  key   String @unique
  value String
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  pushEnabled  Boolean  @default(false)
  telegramChat String?
  source       String   @default("site")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model PromoCode {
  id          String    @id @default(cuid())
  code        String    @unique
  type        String
  value       Int
  minAmount   Int       @default(0)
  maxUses     Int?
  usedCount   Int       @default(0)
  active      Boolean   @default(true)
  validFrom   DateTime?
  validUntil  DateTime?
  description String?
  createdAt   DateTime  @default(now())
}

model PartnershipLead {
  id        String   @id @default(cuid())
  name      String
  company   String?
  phone     String
  message   String?
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model CategoryRedirect {
  id        String   @id @default(cuid())
  fromSlug  String   @unique
  toSlug    String?
  permanent Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  amount      Decimal  @db.Decimal(10, 2)
  category    String
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
}

model CostPrice {
  id           String         @id @default(cuid())
  variantId    String         @unique
  costPerCube  Decimal?       @db.Decimal(10, 2)
  costPerPiece Decimal?       @db.Decimal(10, 2)
  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model Task {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      TaskStatus    @default(TODO)
  priority    TaskPriority  @default(MEDIUM)
  sortOrder   Int           @default(0)
  assigneeId  String?
  createdById String?
  orderId     String?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tags        String[]      @default([])
  assignee    User?         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy   User?         @relation("TaskCreator", fields: [createdById], references: [id])
  order       Order?        @relation(fields: [orderId], references: [id])
  comments    TaskComment[]
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String?
  text      String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
}

model Lead {
  id               String         @id @default(cuid())
  name             String
  phone            String?
  email            String?
  company          String?
  source           LeadSource     @default(WEBSITE)
  stage            LeadStage      @default(NEW)
  value            Decimal?       @db.Decimal(10, 2)
  currency         String         @default("RUB")
  comment          String?
  tags             String[]       @default([])
  assigneeId       String?
  convertedOrderId String?
  convertedAt      DateTime?
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  assignee         User?          @relation("LeadAssignee", fields: [assigneeId], references: [id])
  activities       LeadActivity[]

  @@index([assigneeId, stage])
  @@index([stage])
  @@index([createdAt])
}

model LeadActivity {
  id           String           @id @default(cuid())
  leadId       String
  type         LeadActivityType @default(NOTE)
  text         String
  scheduledFor DateTime?
  completedAt  DateTime?
  userId       String?
  createdAt    DateTime         @default(now())
  lead         Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user         User?            @relation("LeadActivityUser", fields: [userId], references: [id])

  @@index([leadId])
}

model Workflow {
  id          String        @id @default(cuid())
  name        String
  description String?
  active      Boolean       @default(true)
  trigger     String
  conditions  Json          @default("{}")
  actions     Json          @default("[]")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  logs        WorkflowLog[]
}

model WorkflowLog {
  id         String   @id @default(cuid())
  workflowId String
  trigger    String
  payload    Json     @default("{}")
  result     String
  error      String?
  createdAt  DateTime @default(now())
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model ArayMemory {
  id           String    @id @default(cuid())
  userId       String?   @unique
  sessionId    String?   @unique
  facts        Json      @default("{}")
  summary      String    @default("")
  lastMessages Json      @default("[]")
  level        ArayLevel @default(NOVICE)
  totalChats   Int       @default(0)
  totalPoints  Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String
  coverImage  String?
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  aiGenerated Boolean  @default(false)
  topic       String?
  readTime    Int      @default(5)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  content     String
  price       String?
  unit        String?
  image       String?
  icon        String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // VIEW_PRODUCT, PLACE_ORDER, WRITE_REVIEW, LOGIN, PAGE_VISIT
  targetId  String?  // productId, orderId, etc.
  meta      Json?    // extra data (product name, page url, etc.)
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model Subscription {
  id         String   @id @default(cuid())
  userId     String
  targetType String   // "supplier" | "category" | "brand"
  targetId   String
  targetName String
  createdAt  DateTime @default(now())

  @@unique([userId, targetType, targetId])
  @@index([userId])
}

enum Role {
  USER
  ADMIN
  MANAGER
  COURIER
  ACCOUNTANT
  WAREHOUSE
  SELLER
  SUPER_ADMIN
}

enum StaffStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum SaleUnit {
  CUBE
  PIECE
  BOTH
}

enum UnitType {
  CUBE
  PIECE
}

enum OrderStatus {
  NEW
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  IN_DELIVERY
  READY_PICKUP
  COMPLETED
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum LeadSource {
  WEBSITE
  TELEGRAM
  PHONE
  REFERRAL
  PARTNER
  OTHER
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  MEETING
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum LeadActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  TASK
  STAGE_CHANGE
  SYSTEM
}

enum ArayLevel {
  NOVICE
  BUILDER
  MASTER
  PARTNER
}

// ── Учёт токенов ARAY ───────────────────────────────────────────────────────
// ARAY бесплатен для всех. Мы платим Anthropic из 50% дохода ARAY.
// Эта таблица — для отслеживания расходов и оптимизации.
model ArayTokenLog {
  id           String   @id @default(cuid())
  userId       String?  // null = гость
  sessionId    String?  // aray_sid из cookie
  model        String   // claude-haiku-4-5, claude-sonnet-4-6, claude-opus-4-6
  tier         String   // haiku, sonnet, opus
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costUsd      Float    @default(0) // Расчётная стоимость в $
  feature      String   @default("chat") // chat, tts, image, search
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([tier, createdAt])
}

// ─── Единая история чата Арая ───────────────────────────────────────────────
model ArayMessage {
  id        String   @id @default(cuid())
  userId    String?              // null = гость (sessionId)
  sessionId String?              // для гостей — cookie aray_sid
  role      String               // "user" | "assistant"
  content   String   @db.Text    // текст сообщения
  context   Json?                // { page, zone, actions[] }
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
}
